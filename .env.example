# Copia a .env y rellena. NUNCA comitees .env con valores reales.
ENVIRONMENT=dev

# Secreto JWT: genera uno fuerte -> openssl rand -hex 32
JWT_SECRET=

# Postgres
DB_PASSWORD=app

# Admin inicial (creado por app.seed)
ADMIN_EMAIL=admin@example.com
