# Copia a .env y rellena. NUNCA comitees .env con valores reales.
ENVIRONMENT=dev

# Secreto JWT: genera uno fuerte -> openssl rand -hex 32
JWT_SECRET=

# Postgres
DB_PASSWORD=app

# Redis: obligatorio, sin default inseguro -> genera con openssl rand -hex 20
REDIS_PASSWORD=

# Admin inicial (creado por app.seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# football-data.org (opcional; vacío => usa dataset local)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026
